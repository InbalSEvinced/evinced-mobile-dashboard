# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# Coralogix DataPrime API key (find it in Coralogix → API Keys)
CORALOGIX_API_KEY=cxtp_your_key_here

# Optional: Slack bot token for posting refresh notifications to #mobile_analytics
# Create one at https://api.slack.com/apps → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# HubSpot Private App token (for fetching owner/SE/TAM/renewal data)
# Create at: HubSpot → Settings → Integrations → Private Apps → Create
# Required scopes: crm.objects.companies.read, crm.objects.deals.read
HUBSPOT_TOKEN=pat-your-token-here

# Zendesk credentials (for fetching ticket counts per account)
# Find subdomain in your Zendesk URL: https://<subdomain>.zendesk.com
ZENDESK_SUBDOMAIN=evinced
ZENDESK_EMAIL=inbal.sanado@evinced.com
# Generate API token at: Zendesk → Admin → Apps & Integrations → Zendesk API → API Tokens
ZENDESK_API_TOKEN=your-zendesk-token-here
